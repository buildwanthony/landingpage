// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  source    String?  @default("website")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  confirmed Boolean  @default(false)
  active    Boolean  @default(true)

  @@map("newsletter_subscribers")
}

model Resource {
  id          String     @id @default(cuid())
  slug        String     @unique
  title       String
  description String
  category    String
  coverImage  String?
  fileUrl     String?
  published   Boolean    @default(false)
  featured    Boolean    @default(false)
  downloads   Download[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("resources")
}

model Download {
  id         String   @id @default(cuid())
  email      String
  name       String?
  resourceId String
  resource   Resource @relation(fields: [resourceId], references: [id])
  source     String?
  createdAt  DateTime @default(now())

  @@map("downloads")
}

model BlogPost {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  excerpt     String?
  content     String?
  tags        String[]
  published   Boolean  @default(false)
  featured    Boolean  @default(false)
  publishedAt DateTime?
  readingTime Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("blog_posts")
}

model Video {
  id          String   @id @default(cuid())
  youtubeId   String   @unique
  title       String
  description String?
  category    String?
  thumbnail   String?
  duration    String?
  published   Boolean  @default(true)
  featured    Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("videos")
}

model Project {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String
  url         String?
  github      String?
  stack       String[]
  featured    Boolean  @default(false)
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("projects")
}

model PageView {
  id        String   @id @default(cuid())
  path      String
  referrer  String?
  country   String?
  createdAt DateTime @default(now())

  @@map("page_views")
}
